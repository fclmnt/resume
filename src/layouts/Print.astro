---
import '../styles/print.css';
const { lang, title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href={`${base}assets/favicon/favicon.ico`} />
  </head>
  <body>
    <slot />
  </body>
</html>
