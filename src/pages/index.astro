---
const base = import.meta.env.BASE_URL;
const target = `${base}fr/`;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Franck Clement | CV / Resume</title>
  </head>
  <body>
    <p>Redirection… <a href={target}>Français</a> · <a href={`${base}en/`}>English</a></p>
  </body>
</html>
